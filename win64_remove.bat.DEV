@echo off
setlocal
set VENV_NAME=venv

echo [!] WARNING: This will delete the ENTIRE folder and all files within it.
set /p "CONFIRM=Are you sure you want to proceed? (Y/N): "
if /i "%CONFIRM%" neq "Y" (
    echo Aborted.
    pause
    exit /b
)

echo [1/3] Deactivating environment...
call %VENV_NAME%\Scripts\deactivate >nul 2>&1

echo [2/3] Cleaning up...
:: Change directory to the parent folder so we aren't "locked" inside the folder we want to delete
set PROJECT_DIR=%~dp0
cd ..

echo [3/3] Deleting directory: %PROJECT_DIR%
:: The timeout gives the OS a second to release any file locks before the wipe
timeout /t 2 /nobreak >nul

:: /s removes all subdirectories, /q is quiet mode
rd /s /q "%PROJECT_DIR%"

if exist "%PROJECT_DIR%" (
    echo [ERROR] Could not delete the folder. Ensure no files or terminals are open in this directory.
) else (
    echo Wipe complete. This window will now close.
)

pause
exit